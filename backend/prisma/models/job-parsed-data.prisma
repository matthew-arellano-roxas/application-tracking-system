model JobParsedData {
    id          String            @id @default(uuid())
    jobId      String      @unique @map("job_id")
    job        Job      @relation(fields: [jobId], references: [id])
    parsedData Json     @map("parsed_data")
    createdAt  DateTime @default(now()) @map("created_at")

    @@map("job_parsed_data")
}
